<?xml version="1.0"?>
<!DOCTYPE suppressions PUBLIC
        "-//Checkstyle//DTD SuppressionFilter Configuration 1.2//EN"
        "https://checkstyle.org/dtds/suppressions_1_2.dtd">

<suppressions>
    <!-- Suppress errors in generated files -->
    <suppress checks=".*" files="build[\/\\]generated[\/\\].*\.java"/>

    <!-- Suppress Javadoc and magic number errors in test files -->
    <suppress checks="JavadocMethod" files="src[\/\\](integration-)?test[\/\\].*\.java"/>
    <suppress checks="JavadocType" files="src[\/\\](integration-)?test[\/\\].*\.java"/>
    <suppress checks="MagicNumber" files="src[\/\\](integration-)?test[\/\\].*\.java"/>
    <suppress checks="AvoidStaticImport" files="src[\/\\](integration-)?test[\/\\].*\.java"/>
</suppressions>
